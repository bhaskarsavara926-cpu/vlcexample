# Sets the minimum CMake version required for this project.
cmake_minimum_required(VERSION 3.22.1)

# Declares the project name. The project name can be accessed via ${ PROJECT_NAME},
# Since this is the top level CMakeLists.txt, the project name is also accessible
# with ${CMAKE_PROJECT_NAME} (both CMake variables are in-sync within the top level
# build script scope).
project("myvlc")

#target_link_options(myvlc PRIVATE "-Wl,-z,max-page-size=16384")

# Creates and names a library, sets it as either STATIC
# or SHARED, and provides the relative paths to its source code.
# You can define multiple libraries, and CMake builds them for you.
# Gradle automatically packages shared libraries with your APK.
#
# In this top level CMakeLists.txt, ${CMAKE_PROJECT_NAME} is used to define
# the target library name; in the sub-module's CMakeLists.txt, ${PROJECT_NAME}
# is preferred for the same purpose.
#
# In order to load a library into your app from Java/Kotlin, you must call
# System.loadLibrary() and pass the name of the library defined here;
# for GameActivity/NativeActivity derived applications, the same library name must be
# used in the AndroidManifest.xml file.
add_library(myvlc SHARED
        # List C/C++ source files with relative paths to this CMakeLists.txt.
        native-lib.cpp
        dummy.cpp
        libvlcjni.c
        libvlcjni-dialog.c
        libvlcjni-media.c
        libvlcjni-mediadiscoverer.c
        libvlcjni-medialist.c
        libvlcjni-mediaplayer.c
        libvlcjni-rendererdiscoverer.c
        libvlcjni-vlcobject.c
        std_logger.c
        )

include_directories( ${CMAKE_SOURCE_DIR}/include )

# Declare the prebuilt library as an IMPORTED library
add_library(
        # Sets the name of the library (e.g., "mylibrary")
        vlc_library

        # Specifies that the library is prebuilt and not built from source
        SHARED IMPORTED
)

# Specify the location of the prebuilt library file
set_target_properties(
        vlc_library
        PROPERTIES IMPORTED_LOCATION
        ${CMAKE_SOURCE_DIR}/../jniLibs/${ANDROID_ABI}/libvlc.so
)

# Declare the prebuilt library as an IMPORTED library
add_library(
        # Sets the name of the library (e.g., "mylibrary")
        vlcjni_library

        # Specifies that the library is prebuilt and not built from source
        SHARED IMPORTED
)

# Specify the location of the prebuilt library file
set_target_properties(
        vlcjni_library
        PROPERTIES IMPORTED_LOCATION
        ${CMAKE_SOURCE_DIR}/../jniLibs/${ANDROID_ABI}/libvlcjni.so
)

# Specifies libraries CMake should link to your target library. You
# can link libraries from various origins, such as libraries defined in this
# build script, prebuilt third-party libraries, or Android system libraries.
target_link_libraries(myvlc
        # List libraries link to the target library
        vlc_library
        vlcjni_library
        android
        log)